# Copy to `.dev.vars` for local development. `.dev.vars` is gitignored.
# Read by the adapter platform proxy during `vite dev`; production secrets go
# via `wrangler secret put`.

# --- Local dev switches (NEVER set these in production) ---
# Shows the Simulador tab and enables the simulate remote command (drive flows
# without Meta).
DEV_SIMULATOR=true
# Bypasses the Cloudflare Access gate on /admin (there is no Access in front of
# `vite dev`). Fails closed everywhere this is not exactly "true".
DEV_ACCESS_BYPASS=true

# --- Meta WhatsApp Cloud API (kept off locally; WA_ENABLED stays "false") ---
WA_VERIFY_TOKEN=dev-verify-token
WA_APP_SECRET=dev-app-secret
WA_ACCESS_TOKEN=dev-access-token
WA_PHONE_NUMBER_ID=000000000000000

# --- Cloudflare Access AUD (only needed to test the real gate locally) ---
# CF_ACCESS_AUD=your-access-application-aud
