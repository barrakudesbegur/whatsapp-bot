{
	"name": "whatsapp-bot",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"description": "Kudi — Barrakudes de Begur WhatsApp bot (SvelteKit on Cloudflare Workers + D1 + Workers AI)",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4193",
		"prepare": "svelte-kit sync || echo ''",
		"clean:build": "node -e \"for (const d of ['.svelte-kit/cloudflare', '.svelte-kit/output']) require('fs').rmSync(d, { recursive: true, force: true })\"",
		"check": "npm run clean:build && wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"validate": "npm run format:check && npm run lint && npm run check",
		"chat": "node scripts/chat.ts",
		"db:apply:local": "wrangler d1 migrations apply whatsapp-bot --local",
		"db:apply:remote": "wrangler d1 migrations apply whatsapp-bot --remote",
		"db:query:local": "wrangler d1 execute whatsapp-bot --local --command",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"deploy:dry": "npm run build && wrangler deploy --dry-run",
		"gen": "wrangler types"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@fontsource/londrina-solid": "^5.2.7",
		"jose": "^6.2.3",
		"valibot": "^1.4.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.97.0"
	}
}
