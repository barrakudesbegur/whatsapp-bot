{
  "name": "whatsapp-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kudi — Barrakudes de Begur WhatsApp bot (Cloudflare Worker + Hono + D1 + Workers AI)",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run typecheck && npm run test",
    "deploy:dry": "wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply whatsapp-bot --local",
    "db:query:local": "wrangler d1 execute whatsapp-bot --local --command"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.20.0"
  }
}
